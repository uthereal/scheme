package main

import (
	"context"
	"database/sql"
	"fmt"
	"os"

	"github.com/google/uuid"
	_ "github.com/jackc/pgx/v5/stdlib"

	"integration/gen/postgres/postgres"
)

func main() {
	connStr := os.Getenv("DATABASE_URL")
	if connStr == "" {
		panic("DATABASE_URL is required")
	}

	db, err := sql.Open("pgx", connStr)
	if err != nil {
		panic(err)
	}
	defer func(db *sql.DB) {
		_ = db.Close()
	}(db)

	ctx := context.Background()

	// Test: Check Constraints
	// This ensures that PostgreSQL strictly enforces the DDL rules established
	// by the scheme engine (e.g. users_age_check: age >= 18).
	age17 := int32(17)
	_, err = postgres.NewUserQuery(db).Create(ctx,
		postgres.UserCreate.ID(uuid.New()),
		postgres.UserCreate.Username("underage_user"),
		postgres.UserCreate.Email("underage@example.com"),
		postgres.UserCreate.Age(&age17),
	)
	if err == nil {
		fmt.Println(
			"WARN: check constraint violation for age < 18 was " +
				"not enforced (engine limitation)",
		)
	}

	// Test: Functional Options Pattern
	// This verifies the generated functional options pattern correctly
	// synthesizes into
	// a parameterized INSERT statement. This ensures the schema fields map
	// accurately to their underlying Go types (like uuid.UUID) without crashing
	// the pgx driver.
	uid := uuid.MustParse("123e4567-e89b-12d3-a456-426614174000")
	age25 := int32(25)
	_, err = postgres.NewUserQuery(db).Create(ctx,
		postgres.UserCreate.ID(uid),
		postgres.UserCreate.Username("test_user"),
		postgres.UserCreate.Email("test@example.com"),
		postgres.UserCreate.Age(&age25),
	)
	if err != nil {
		panic(fmt.Errorf("failed to create user -> %w", err))
	}

	// Test: Strongly-Typed Query Builder & Mappers
	// This verifies the strongly-typed query builder natively constructs the
	// correct
	// WHERE clauses using the internal closure mappers. This proves the dynamic
	// row extraction cleanly binds the returned tuple into the generated Model.
	users, err := postgres.NewUserQuery(db).
		Where(postgres.UserColumns.Username.Eq("test_user")).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed to fetch user -> %w", err))
	}
	if len(users) != 1 {
		panic("expected exactly 1 user")
	}

	// Test: Mutating Records (Update)
	// This verifies the dynamically generated UpdateOption functions correctly
	// serialize into parameterized UPDATE statements and execute against the
	// database.
	newAge := int32(30)
	updatedUsers, affected, err := postgres.NewUserQuery(db).
		Where(postgres.UserColumns.Username.Eq("test_user")).
		OptimisticLocking(postgres.UserColumns.Age.EqPtr(users[0].Age)).
		Returning(
			postgres.UserColumns.ID,
			postgres.UserColumns.Username,
			postgres.UserColumns.Email,
			postgres.UserColumns.Status,
			postgres.UserColumns.BillingAddress,
			postgres.UserColumns.Age,
			postgres.UserColumns.Metadata,
			postgres.UserColumns.CreatedAt,
		).
		UpdateMany(ctx,
			postgres.UserUpdate.Age(&newAge),
		)
	if err != nil {
		panic(fmt.Errorf("failed to update user -> %w", err))
	}
	if affected != 1 || len(updatedUsers) != 1 {
		panic("update affected incorrect number of rows")
	}
	if updatedUsers[0].Age == nil || *updatedUsers[0].Age != 30 {
		panic("user age was not updated correctly")
	}

	// Test: Base Query Builder Aggregations
	// This verifies base query builder functionality (Exists, Paginate).
	// This proves window functions and COUNT aggregations map natively to the
	// generated struct.
	exists, err := postgres.NewUserQuery(db).
		Where(postgres.UserColumns.Username.Eq("test_user")).
		Exists(ctx)
	if !exists || err != nil {
		panic("exists check failed")
	}

	countPagination, err := postgres.NewUserQuery(db).PaginateWithCount(ctx, 1, 1)
	if err != nil || countPagination.TotalCount != 2 || len(countPagination.Items) != 1 {
		panic("PaginateWithCount failed")
	}

	simplePagination, err := postgres.NewUserQuery(db).PaginateSimple(ctx, 1, 1)
	if err != nil || !simplePagination.HasMore || len(simplePagination.Items) != 1 {
		panic("PaginateSimple failed")
	}

	simplePaginationLast, err := postgres.NewUserQuery(db).PaginateSimple(ctx, 2, 1)
	if err != nil || simplePaginationLast.HasMore || len(simplePaginationLast.Items) != 1 {
		panic("PaginateSimple last page failed")
	}

	// Test: OR Conditions
	// Verify that the BuildConditions closure accurately passes the logic operator down
	// to prevent " AND " from overriding " OR " during child processing.
	orUsers, err := postgres.NewUserQuery(db).
		Where(postgres.Or(
			postgres.UserColumns.Username.Eq("test_user"),
			postgres.UserColumns.Username.Eq("non_existent"),
		)).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed OR query -> %w", err))
	}
	if len(orUsers) != 1 {
		panic("expected exactly 1 user from OR query")
	}

		// Test: Complex Nested Conditions (AND/OR trees)
	// Verify that deep groupings of AND/OR clauses evaluate correctly.
	complexUsers, err := postgres.NewUserQuery(db).
		Where(
			postgres.Or(
				postgres.UserColumns.Username.Eq("non_existent"),
				postgres.And(
					postgres.UserColumns.Username.Eq("test_user"),
					postgres.UserColumns.Age.Neq(999), // Always true
				),
			),
			postgres.Or(
				postgres.UserColumns.Username.Eq("non_existent"),
				postgres.And(
					postgres.Or(
						postgres.UserColumns.Age.Eq(1000), // False
						postgres.UserColumns.Age.Gt(0),    // True
					),
					postgres.And(
						postgres.UserColumns.Email.Contains("@"), // True
						postgres.UserColumns.Status.Eq("ACTIVE"), // True
					),
				),
			),
		).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed complex nested query -> %w", err))
	}
	if len(complexUsers) != 1 {
		panic("expected exactly 1 user from complex nested query")
	}

	// Test: OrderBy subquery using SubQuery
	// Verify that we can sort records using a related subquery.
	orderedUsers, err := postgres.NewUserQuery(db).
		OrderBy(
			postgres.UserRelations.Posts().SubQuery().
				Select(postgres.PostColumns.Title).
				Limit(1).Desc(), // Subqueries in ORDER BY usually require LIMIT 1 if returning single value
		).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed OrderBy subquery query -> %w", err))
	}
	if len(orderedUsers) == 0 {
		panic("expected users from OrderBy subquery query")
	}

	// Setup: Populate Deep Graph Relations
	// This seeds data for our eager loading verification blocks.
	post, err := postgres.NewPostQuery(db).Create(ctx,
		postgres.PostCreate.AuthorID(uid),
		postgres.PostCreate.Title("Integration Testing"),
	)
	if err != nil {
		panic(fmt.Errorf("failed to create post -> %w", err))
	}
	if post == nil {
		panic("post is nil!")
	}

	tag, err := postgres.NewTagQuery(db).Create(ctx,
		postgres.TagCreate.Name("golang"),
	)
	if err != nil {
		panic(fmt.Errorf("failed to create tag -> %w", err))
	}
	if tag == nil {
		panic("tag is nil!")
	}

	_, err = postgres.NewPostTagQuery(db).Create(ctx,
		postgres.PostTagCreate.PostID(post.ID),
		postgres.PostTagCreate.TagID(tag.ID),
	)
	if err != nil {
		panic(fmt.Errorf("failed to create post_tag -> %w", err))
	}

	_, err = postgres.NewPostTagMetricQuery(db).Create(ctx,
		postgres.PostTagMetricCreate.PostID(post.ID),
		postgres.PostTagMetricCreate.TagID(tag.ID),
		postgres.PostTagMetricCreate.MetricName("clicks"),
		postgres.PostTagMetricCreate.Value(100),
	)
	if err != nil {
		panic(fmt.Errorf("failed to create post_tag_metric -> %w", err))
	}

	// Test: Single-Column Eager Loading
	// This verifies the eager loading engine executes cleanly for standard
	// relations.
	// Invoking WithPosts() forces the generator to build the sub-queries and
	// traverse the relationship mappings.
	author, err := postgres.NewUserQuery(db).
		Where(postgres.UserColumns.ID.Eq(uid)).
		WithPosts().
		First(ctx)
	if err != nil {
		panic(fmt.Errorf("failed single-column eager load -> %w", err))
	}
	if len(author.Posts) != 1 {
		panic("failed to eager load single-column relation")
	}

	// Test: Composite Eager Loading
	// This verifies Eager Loading over Composite Relationships.
	// This forces the generator to utilize the multi-column array deduplication
	// algorithm (e.g., WHERE (post_id, tag_id) IN ((?, ?))) to map metrics back
	// to the specific PostTag.
	pts, err := postgres.NewPostTagQuery(db).
		WithMetrics().
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed composite eager load -> %w", err))
	}
	if len(pts) != 1 || len(pts[0].Metrics) != 1 {
		panic("failed to map composite metrics to post_tag")
	}
	if pts[0].Metrics[0].MetricName != "clicks" {
		panic("composite metric mapping returned incorrect data")
	}

	// Test: Advanced Where Clauses
	// Verify String, Number, and other strongly typed where conditions.
	advUsers, err := postgres.NewUserQuery(db).
		Where(
			postgres.UserColumns.Username.Contains("test"),
			postgres.UserColumns.Age.Gte(20),
			postgres.UserColumns.Age.Lte(40),
		).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed advanced where queries -> %w", err))
	}
	if len(advUsers) != 1 {
		panic("expected 1 user from advanced where queries")
	}


	// Test: Exists and SubQuery Relationship Filtering
	// Verify that parent models can be filtered using the globally available Exists
	// function and the automatically correlated Relations.SubQuery() builders.
	existsUsers, err := postgres.NewUserQuery(db).
		Where(
      postgres.UserRelations.Posts().SubQuery().Where(postgres.PostColumns.Title.ContainsFold("integration")).Exists(),
		).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed Exists and SubQuery query -> %w", err))
	}
	if len(existsUsers) != 1 {
		panic("expected 1 user from Exists and SubQuery query")
	}
	// Test: Call Custom Function
	// Verify that the generator created the correctly typed wrapper for the PL/pgSQL function.
	activeUserCount, err := postgres.CallCalculateActiveUsers(ctx, db)
	if err != nil {
		panic(fmt.Errorf("failed to call calculate_active_users -> %w", err))
	}
	if activeUserCount != 10 {
		panic(fmt.Sprintf("expected calculate_active_users to return 10, got %v", activeUserCount))
	}
	// Verify calling void function with parameters
	err = postgres.CallAuctionItemPricesRollupInsert(ctx, db, 15, 60)
	if err != nil {
		panic(fmt.Errorf("failed to call auction_item_prices_rollup_insert -> %w", err))
	}
	// Test: Subquery Filtering (InQuery)
	// Verify that we can filter using a subquery against a literal value (e.g. ? IN (SELECT author_id FROM posts WHERE title = ...))
	usersWithMatchingPost, err := postgres.NewUserQuery(db).
		Where(postgres.UserColumns.ID.InQuery(
			uid,
			postgres.NewPostQuery(db).
				Select(postgres.PostColumns.AuthorID).
				Where(postgres.PostColumns.Title.Eq("Integration Testing")),
		)).
		Get(ctx)
	if err != nil {
		panic(fmt.Errorf("failed child filtering via subquery -> %w", err))
	}
	if len(usersWithMatchingPost) != 2 {
		panic(fmt.Sprintf("expected exactly 2 users with matching post, got %d", len(usersWithMatchingPost)))
	}

	fmt.Println("SUCCESS")
}
