# proto-file: proto/scheme.proto
# proto-message: scheme.Scheme

databases: {
  name: "postgres"
  postgres: {
    schemas: {
      name: "public"
      enums: [
        { name: "user_status", values: ["ACTIVE", "INACTIVE", "BANNED", "PENDING"] }
      ]
      composites: [
        {
          name: "address"
          fields: [
            { name: "street", type: { varchar_type: { length: 255 } } },
            { name: "city", type: { varchar_type: { length: 100 } } },
            { name: "zip", type: { varchar_type: { length: 20 } } }
          ]
        }
      ]
      domains: [
        { name: "email_address", base_type: { varchar_type: { length: 255 } } }
      ]
      tables: [
        {
          name: "users"
          columns: [
            { name: "id", type: { uuid_type: {} }, default_value: "gen_random_uuid()" },
            { name: "handle", name_previous: "username", type: { varchar_type: { length: 50 } } },
            { name: "email", type: { domain_type: { name: "email_address", schema: "public" } } },
            {
              name: "status",
              type: { enum_type: { name: "user_status", schema: "public" } },
              default_value: "'INACTIVE'"
            },
            {
              name: "billing_address",
              type: { composite_type: { name: "address", schema: "public" } },
              is_nullable: true
            },

            { name: "metadata", type: { jsonb_type: {} }, is_nullable: false, default_value: "'{}'" },
            { name: "last_login_at", type: { timestamptz_type: {} }, is_nullable: true },
            { name: "created_at", type: { timestamptz_type: { precision: 6 } }, default_value: "now()" }
          ]
          primary_keys: ["id"]
          indexes: [
            { name: "users_handle_key", columns: [{ name: "handle" }], is_unique: true },
            { name: "users_created_at_idx", columns: [{ name: "created_at" }] }
          ]
          checks: [
            { name: "users_handle_check", column: "handle", predicate: "handle != ''" }
          ]
          relations: [
            {
              name: "posts"
              type: RELATION_TYPE_ONE_TO_MANY
              target_table: "posts"
              columns: [{ source_column: "id", target_column: "author_id" }]
            }
          ]
        },
        {
          name: "user_sessions"
          columns: [
            { name: "id", type: { uuid_type: {} }, default_value: "gen_random_uuid()" },
            { name: "user_id", type: { uuid_type: {} } }
          ]
        },
        {
          name: "posts"
          columns: [
            { name: "id", type: { bigserial_type: {} } },
            { name: "author_id", type: { uuid_type: {} } },
            { name: "title", type: { varchar_type: { length: 255 } } },
            { name: "body", type: { text_type: {} }, is_nullable: false, default_value: "''" },
            { name: "views", type: { bigint_type: {} }, default_value: "0" }
          ]
          primary_keys: ["id"]
          foreign_keys: [
            {
              name: "fk_posts_author"
              target_table: "users"
              columns: [{ source_column: "author_id", target_column: "id" }]
              on_delete: FOREIGN_KEY_ACTION_SET_NULL
            }
          ]
          relations: [
            {
              name: "author"
              type: RELATION_TYPE_MANY_TO_ONE
              target_table: "users"
              columns: [{ source_column: "author_id", target_column: "id" }]
            },
            {
              name: "post_tags"
              type: RELATION_TYPE_ONE_TO_MANY
              target_table: "post_tags"
              columns: [{ source_column: "id", target_column: "post_id" }]
            }
          ]
        },
        {
          name: "tags"
          columns: [
            { name: "id", type: { serial_type: {} } },
            { name: "name", type: { varchar_type: { length: 50 } } }
          ]
          primary_keys: ["id"]
          indexes: [
            { name: "tags_name_key", columns: [{ name: "name" }], is_unique: true }
          ]
        },
        {
          name: "post_tags"
          columns: [
            { name: "post_id", type: { bigint_type: {} } },
            { name: "tag_id", type: { integer_type: {} } }
          ]
          primary_keys: ["post_id", "tag_id"]
          foreign_keys: [
            {
              name: "fk_post_tags_post"
              target_table: "posts"
              columns: [{ source_column: "post_id", target_column: "id" }]
              on_delete: FOREIGN_KEY_ACTION_CASCADE
            },
            {
              name: "fk_post_tags_tag"
              target_table: "tags"
              columns: [{ source_column: "tag_id", target_column: "id" }]
              on_delete: FOREIGN_KEY_ACTION_CASCADE
            }
          ]
          relations: [
            {
              name: "metrics"
              type: RELATION_TYPE_ONE_TO_MANY
              target_table: "post_tag_metrics"
              columns: [
                { source_column: "post_id", target_column: "post_id" },
                { source_column: "tag_id", target_column: "tag_id" }
              ]
            }
          ]
        },
        {
          name: "post_tag_metrics"
          columns: [
            { name: "post_id", type: { bigint_type: {} } },
            { name: "tag_id", type: { integer_type: {} } },
            { name: "metric_name", type: { varchar_type: { length: 50 } } },
            { name: "value", type: { integer_type: {} }, default_value: "0" }
          ]
          primary_keys: ["post_id", "tag_id", "metric_name"]
          foreign_keys: [
            {
              name: "fk_pt_metrics_pt"
              target_table: "post_tags"
              columns: [
                { source_column: "post_id", target_column: "post_id" },
                { source_column: "tag_id", target_column: "tag_id" }
              ]
              on_delete: FOREIGN_KEY_ACTION_CASCADE
            }
          ]
        }
      ]
    }
    schemas: {
      name: "security"
      name_previous: "audit"
      enums: [
        { name: "severity_level", name_previous: "log_level", values: ["INFO", "ERROR"] }
      ]
      composites: [
        {
          name: "coordinates",
          name_previous: "geo_location",
          fields: [
            { name: "lat", type: { real_type: {} } },
            { name: "lon", type: { real_type: {} } }
          ]
        }
      ]
      domains: [
        { name: "network_address", name_previous: "ip_address", base_type: { varchar_type: { length: 45 } } }
      ]
      tables: [
        {
          name: "system_logs"
          name_previous: "temporary_logs"
          columns: [
            { name: "id", type: { uuid_type: {} }, default_value: "gen_random_uuid()" },
            { name: "level", type: { enum_type: { name: "severity_level", schema: "security" } } },
            { name: "source_ip", type: { domain_type: { name: "network_address", schema: "security" } } },
            { name: "location", type: { composite_type: { name: "coordinates", schema: "security" } } }
          ]
        }
      ]
    }
    schemas: {
      name: "analytics"
      tables: [
        {
          name: "events"
          columns: [
            { name: "id", type: { uuid_type: {} } }
          ]
        }
      ]
    }
  }
}
