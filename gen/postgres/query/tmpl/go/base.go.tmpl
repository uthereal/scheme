{{- /* gotype: github.com/uthereal/scheme/gen/postgres/ast.ModelGo */ -}}

{{- $modelNameExported := .Name }}
{{- $modelNamePrivate := .StructNamePrivate }}

// {{ $modelNameExported }}Query represents a strongly typed query builder for
// the {{ .TableFullName }} table.
type {{ $modelNameExported }}Query struct {
  db        rootpkg.DBQuerier
  alias     string
  selects   []rootpkg.Column
  returning []rootpkg.Column
  wheres    []rootpkg.WhereCondition
  groupBys  []rootpkg.Column
  havings   []rootpkg.WhereCondition
  orderBys  []{{ $modelNamePrivate }}OrderBy
  limit     *int
  offset    *int

  {{- range .Edges }}
    with{{ .Name }} *{{ .TargetModel }}Query
  {{- end }}
}

// As aliases the table for this query.
func (q *{{ $modelNameExported }}Query) As(
  alias string,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.alias = alias
  return &clone
}

// {{ $modelNameExported }}CountPagination holds a paginated result set of
// {{ $modelNameExported }} alongside the total count of available records.
type {{ $modelNameExported }}CountPagination struct {
  Items      []*{{ $modelNameExported }}
  TotalCount int
}

// {{ $modelNameExported }}SimplePagination holds a paginated result set of
// {{ $modelNameExported }} and a boolean indicating if more records exist.
type {{ $modelNameExported }}SimplePagination struct {
  Items   []*{{ $modelNameExported }}
  HasMore bool
}

// {{ $modelNamePrivate }}OrderBy defines a single ORDER BY constraint for a
// {{ $modelNameExported }}Query.
type {{ $modelNamePrivate }}OrderBy struct {
  Column    string
  Query     rootpkg.SubQuery
  Direction rootpkg.OrderDirection
}

// {{ $modelNamePrivate }}ColumnsStruct defines strongly typed columns for the
// {{ .TableFullName }} table.
type {{ $modelNamePrivate }}ColumnsStruct struct {
  {{- range .Fields }}
    {{ .Name }} {{ .String }}
  {{- end }}
}

// As returns a new {{ $modelNamePrivate }}ColumnsStruct with all columns
// prefixed by the provided table alias.
func (s {{ $modelNamePrivate }}ColumnsStruct) As(
  alias string,
) {{ $modelNamePrivate }}ColumnsStruct {
  return {{ $modelNamePrivate }}ColumnsStruct{
  {{- range .Fields }}
    {{ .Name }}: {{ .String }}{
      rootpkg.BaseColumn(alias + ".{{ .ColumnName }}"),
      {{- if .Category.SupportOperatorEquality }}
        rootpkg.ComparableColumn[{{ .GoBaseType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
      {{- if .Category.SupportOperatorMembership }}
        rootpkg.ArrayableColumn[{{ .GoBaseType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
      {{- if .Category.SupportOperatorRelational }}
        rootpkg.OrderableColumn[{{ .GoBaseType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
    },
  {{- end }}
  }
}

// {{ $modelNameExported }}Select defines strongly typed columns for the
// {{ .TableFullName }} table.
var {{ $modelNameExported }}Columns = {{ $modelNamePrivate }}ColumnsStruct{
  {{- range .Fields }}
    {{ .Name }}: {{ .String }}{
      rootpkg.BaseColumn("{{ .ColumnName }}"),
      {{- if .Category.SupportOperatorEquality }}
        rootpkg.ComparableColumn[{{ .GoBaseType }}]("{{ .ColumnName }}"),
      {{- end }}
      {{- if .Category.SupportOperatorMembership }}
        rootpkg.ArrayableColumn[{{ .GoBaseType }}]("{{ .ColumnName }}"),
      {{- end }}
      {{- if .Category.SupportOperatorRelational }}
        rootpkg.OrderableColumn[{{ .GoBaseType }}]("{{ .ColumnName }}"),
      {{- end }}
    },
  {{- end }}
}

// {{ $modelNamePrivate }}RelationsStruct defines strongly typed relationships for the
// {{ .TableFullName }} table.
type {{ $modelNamePrivate }}RelationsStruct struct {
  cols {{ $modelNamePrivate }}ColumnsStruct
}

// As returns a new {{ $modelNamePrivate }}RelationsStruct with the parent columns
// aliased by the provided table alias.
func (r {{ $modelNamePrivate }}RelationsStruct) As(
  alias string,
) {{ $modelNamePrivate }}RelationsStruct {
  return {{ $modelNamePrivate }}RelationsStruct{cols: {{ $modelNameExported }}Columns.As(alias)}
}

var {{ $modelNameExported }}Relations = {{ $modelNamePrivate }}RelationsStruct{
  cols: {{ $modelNameExported }}Columns.As(`{{ .TableFullName }}`),
}

{{- range .Edges }}
  {{- $edge := . }}
  // {{ $modelNamePrivate }}{{ .Name }}Relation represents a strongly typed relationship builder for the
  // {{ .Name }} edge.
  type {{ $modelNamePrivate }}{{ .Name }}Relation struct {
    cols {{ $modelNamePrivate }}ColumnsStruct
  }

  // {{ .Name }} returns a relation builder for the {{ .Name }} edge.
  func (r {{ $modelNamePrivate }}RelationsStruct) {{ .Name }}() {{ $modelNamePrivate }}{{ .Name }}Relation {
    return {{ $modelNamePrivate }}{{ .Name }}Relation{cols: r.cols}
  }

  // SubQuery returns a {{ .TargetModel }}SubQuery automatically correlated to the parent table.
  func (r {{ $modelNamePrivate }}{{ .Name }}Relation) SubQuery() *{{ .TargetModel }}SubQuery {
    q := &{{ .TargetModel }}SubQuery{}
    return q.Where(
      {{- range $i, $lf := .LocalFields }}
        {{- $tf := index $edge.TargetFields $i }}
        {{ $edge.TargetModel }}Columns.{{ $tf }}.EqCol(r.cols.{{ $lf }}),
      {{- end }}
    )
  }
{{- end }}


// New{{ $modelNameExported }}Query constructs a new
// {{ $modelNameExported }}Query scoped to the provided database connection.
func New{{ $modelNameExported }}Query(
  db rootpkg.DBQuerier,
) *{{ $modelNameExported }}Query {
  if db == nil {
    panic("database connection cannot be nil")
  }
  return &{{ $modelNameExported }}Query{
    db: db,
  }
}

// Select specifies the exact columns to retrieve from the database.
func (q *{{ $modelNameExported }}Query) Select(
  cols ...rootpkg.Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.selects = make([]rootpkg.Column, len(q.selects), len(q.selects)+len(cols))
  copy(clone.selects, q.selects)
  clone.selects = append(clone.selects, cols...)
  return &clone
}

// Returning specifies the exact columns to return after a mutation operation.
func (q *{{ $modelNameExported }}Query) Returning(
  cols ...rootpkg.Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.returning = make([]rootpkg.Column, len(q.returning), len(q.returning)+len(cols))
  copy(clone.returning, q.returning)
  clone.returning = append(clone.returning, cols...)
  return &clone
}

// Where adds one or more conditional constraints to the query.
func (q *{{ $modelNameExported }}Query) Where(
  conds ...rootpkg.WhereCondition,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.wheres = make([]rootpkg.WhereCondition, len(q.wheres), len(q.wheres)+len(conds))
  copy(clone.wheres, q.wheres)
  clone.wheres = append(clone.wheres, conds...)
  return &clone
}

// OptimisticLocking provides a semantic alias for Where(), specifically intended
// to assert row version or timestamp constraints during an update.
func (q *{{ $modelNameExported }}Query) OptimisticLocking(
  conds ...rootpkg.WhereCondition,
) *{{ $modelNameExported }}Query {
  return q.Where(conds...)
}

// GroupBy applies a grouping constraint to the query.
func (q *{{ $modelNameExported }}Query) GroupBy(
  cols ...rootpkg.Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.groupBys = make([]rootpkg.Column, len(q.groupBys), len(q.groupBys)+len(cols))
  copy(clone.groupBys, q.groupBys)
  clone.groupBys = append(clone.groupBys, cols...)
  return &clone
}

// Having adds one or more conditional constraints to the GROUP BY clause.
func (q *{{ $modelNameExported }}Query) Having(
  conds ...rootpkg.WhereCondition,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.havings = make(
    []rootpkg.WhereCondition, len(q.havings), len(q.havings)+len(conds),
  )
  copy(clone.havings, q.havings)
  clone.havings = append(clone.havings, conds...)
  return &clone
}

// OrderBy applies a sorting constraint to the query.
func (q *{{ $modelNameExported }}Query) OrderBy(
  col rootpkg.Column, dir rootpkg.OrderDirection,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.orderBys = make(
    []{{ $modelNamePrivate }}OrderBy, len(q.orderBys), len(q.orderBys)+1,
  )
  copy(clone.orderBys, q.orderBys)
  clone.orderBys = append(clone.orderBys, {{ $modelNamePrivate }}OrderBy{
    Column: col.String(), Direction: dir,
  })
  return &clone
}

// OrderByQuery applies a sorting constraint using a sub-query.
func (q *{{ $modelNameExported }}Query) OrderByQuery(
  query rootpkg.SubQuery, dir rootpkg.OrderDirection,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.orderBys = make(
    []{{ $modelNamePrivate }}OrderBy, len(q.orderBys), len(q.orderBys)+1,
  )
  copy(clone.orderBys, q.orderBys)
  clone.orderBys = append(clone.orderBys, {{ $modelNamePrivate }}OrderBy{
    Query: query, Direction: dir,
  })
  return &clone
}

// Limit sets the maximum number of records to return.
func (q *{{ $modelNameExported }}Query) Limit(
  limit int,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.limit = &limit
  return &clone
}

// Offset sets the number of records to skip before returning results.
func (q *{{ $modelNameExported }}Query) Offset(
  offset int,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.offset = &offset
  return &clone
}

{{- range .Edges }}
  // With{{ .Name }} tells the query-builder to eager-load the nodes that
  // are connected to the "{{ .NameLower }}" edge.
    func (q *{{ $modelNameExported }}Query) With{{ .Name }}(
    opts ...func(*{{ .TargetModel }}Query),
  ) *{{ $modelNameExported }}Query {
    clone := *q
    query := New{{ .TargetModel }}Query(q.db)
    for _, opt := range opts {
      opt(query)
    }
    clone.with{{ .Name }} = query
    return &clone
  }
{{- end }}
