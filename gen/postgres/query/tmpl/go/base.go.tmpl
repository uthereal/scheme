{{- /* gotype: github.com/scheme/gen/postgres/ast.ModelData */ -}}

{{- $modelNameExported := .StructNameExported }}
{{- $modelNamePrivate := .StructNamePrivate }}

// {{ $modelNameExported }}Query represents a strongly typed query builder for
// the {{ .TableFullName }} table.
type {{ $modelNameExported }}Query struct {
  db        DBQuerier
  alias     string
  selects   []Column
  returning []Column
  wheres    []WhereCondition
  groupBys  []Column
  havings   []WhereCondition
  orderBys  []{{ $modelNamePrivate }}OrderBy
  limit     *int
  offset    *int

  {{- range .Edges }}
    with{{ .Name }}      *{{ .TargetModel }}Query
    withNamed{{ .Name }} map[string]*{{ .TargetModel }}Query
  {{- end }}
}

// As aliases the table for this query.
func (q *{{ $modelNameExported }}Query) As(
  alias string,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.alias = alias
  return &clone
}

// {{ $modelNameExported }}Pagination holds a paginated result set of
// {{ $modelNameExported }} alongside the total count of available records.
type {{ $modelNameExported }}Pagination struct {
  Items      []*{{ $modelNameExported }}
  TotalCount int
}

// {{ $modelNamePrivate }}OrderBy defines a single ORDER BY constraint for a
// {{ $modelNameExported }}Query.
type {{ $modelNamePrivate }}OrderBy struct {
  Column    string
  Query     QueryBuilder
  Direction OrderDirection
}

// {{ $modelNamePrivate }}SelectStruct defines strongly typed columns for the
// {{ .TableFullName }} table.
type {{ $modelNamePrivate }}SelectStruct struct {
  {{- range .Fields }}
    {{ .Name }} {{ .ColumnType }}
  {{- end }}
}

// As returns a new {{ $modelNamePrivate }}SelectStruct with all columns
// prefixed by the provided table alias.
func (s {{ $modelNamePrivate }}SelectStruct) As(
  alias string,
) {{ $modelNamePrivate }}SelectStruct {
  return {{ $modelNamePrivate }}SelectStruct{
  {{- range .Fields }}
    {{ .Name }}: {{ .ColumnType }}{
      baseColumn(alias + ".{{ .ColumnName }}"),
      {{- if .ColumnType.SupportOperatorEquality }}
        comparableColumn[{{ .ColumnType.GetType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
      {{- if .ColumnType.SupportOperatorMembership }}
        arrayableColumn[{{ .ColumnType.GetType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
      {{- if .ColumnType.SupportOperatorRelational }}
        orderableColumn[{{ .ColumnType.GetType }}](
          alias + ".{{ .ColumnName }}",
        ),
      {{- end }}
    },
  {{- end }}
  }
}

// {{ $modelNameExported }}Select defines strongly typed columns for the
// {{ .TableFullName }} table.
var {{ $modelNameExported }}Select = {{ $modelNamePrivate }}SelectStruct{
  {{- range .Fields }}
    {{ .Name }}: {{ .ColumnType }}{
      baseColumn("{{ .ColumnName }}"),
      {{- if .ColumnType.SupportOperatorEquality }}
        comparableColumn[{{ .ColumnType.GetType }}]("{{ .ColumnName }}"),
      {{- end }}
      {{- if .ColumnType.SupportOperatorMembership }}
        arrayableColumn[{{ .ColumnType.GetType }}]("{{ .ColumnName }}"),
      {{- end }}
      {{- if .ColumnType.SupportOperatorRelational }}
        orderableColumn[{{ .ColumnType.GetType }}]("{{ .ColumnName }}"),
      {{- end }}
    },
  {{- end }}
}

// {{ $modelNameExported }}SelectAll contains all columns of the
// {{ .TableName }} table.
var {{ $modelNameExported }}SelectAll = []Column{
  {{- range .Fields }}
    {{ $modelNameExported }}Select.{{ .Name }},
  {{- end }}
}

// New{{ $modelNameExported }}Query constructs a new
// {{ $modelNameExported }}Query scoped to the provided database connection.
func New{{ $modelNameExported }}Query(
  db DBQuerier,
) *{{ $modelNameExported }}Query {
  if db == nil {
    panic("database connection cannot be nil")
  }
  return &{{ $modelNameExported }}Query{
    db: db,
  }
}

// Select specifies the exact columns to retrieve from the database.
func (q *{{ $modelNameExported }}Query) Select(
  cols ...Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.selects = make([]Column, len(q.selects), len(q.selects)+len(cols))
  copy(clone.selects, q.selects)
  clone.selects = append(clone.selects, cols...)
  return &clone
}

// Returning specifies the exact columns to return after a mutation operation.
func (q *{{ $modelNameExported }}Query) Returning(
  cols ...Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.returning = make([]Column, len(q.returning), len(q.returning)+len(cols))
  copy(clone.returning, q.returning)
  clone.returning = append(clone.returning, cols...)
  return &clone
}

// Where adds one or more conditional constraints to the query.
func (q *{{ $modelNameExported }}Query) Where(
  conds ...WhereCondition,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.wheres = make([]WhereCondition, len(q.wheres), len(q.wheres)+len(conds))
  copy(clone.wheres, q.wheres)
  clone.wheres = append(clone.wheres, conds...)
  return &clone
}

// GroupBy applies a grouping constraint to the query.
func (q *{{ $modelNameExported }}Query) GroupBy(
  cols ...Column,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.groupBys = make([]Column, len(q.groupBys), len(q.groupBys)+len(cols))
  copy(clone.groupBys, q.groupBys)
  clone.groupBys = append(clone.groupBys, cols...)
  return &clone
}

// Having adds one or more conditional constraints to the GROUP BY clause.
func (q *{{ $modelNameExported }}Query) Having(
  conds ...WhereCondition,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.havings = make(
    []WhereCondition, len(q.havings), len(q.havings)+len(conds),
  )
  copy(clone.havings, q.havings)
  clone.havings = append(clone.havings, conds...)
  return &clone
}

// OrderBy applies a sorting constraint to the query.
func (q *{{ $modelNameExported }}Query) OrderBy(
  col Column, dir OrderDirection,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.orderBys = make(
    []{{ $modelNamePrivate }}OrderBy, len(q.orderBys), len(q.orderBys)+1,
  )
  copy(clone.orderBys, q.orderBys)
  clone.orderBys = append(clone.orderBys, {{ $modelNamePrivate }}OrderBy{
    Column: col.String(), Direction: dir,
  })
  return &clone
}

// OrderByQuery applies a sorting constraint using a sub-query.
func (q *{{ $modelNameExported }}Query) OrderByQuery(
  query QueryBuilder, dir OrderDirection,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.orderBys = make(
    []{{ $modelNamePrivate }}OrderBy, len(q.orderBys), len(q.orderBys)+1,
  )
  copy(clone.orderBys, q.orderBys)
  clone.orderBys = append(clone.orderBys, {{ $modelNamePrivate }}OrderBy{
    Query: query, Direction: dir,
  })
  return &clone
}

// Limit sets the maximum number of records to return.
func (q *{{ $modelNameExported }}Query) Limit(
  limit int,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.limit = &limit
  return &clone
}

// Offset sets the number of records to skip before returning results.
func (q *{{ $modelNameExported }}Query) Offset(
  offset int,
) *{{ $modelNameExported }}Query {
  clone := *q
  clone.offset = &offset
  return &clone
}

{{- range .Edges }}
  // With{{ .Name }} tells the query-builder to eager-load the nodes that
  // are connected to the "{{ .NameLower }}" edge.
  func (q *{{ $modelNameExported }}Query) With{{ .Name }}(
    opts ...func(*{{ .TargetModel }}Query),
  ) *{{ $modelNameExported }}Query {
    clone := *q
    query := New{{ .TargetModel }}Query(q.db)
    for _, opt := range opts {
      opt(query)
    }
    clone.with{{ .Name }} = query
    return &clone
  }

  // WithNamed{{ .Name }} tells the query-builder to eager-load the nodes
  // that are connected to the "{{ .NameLower }}" edge, and populates
  // the given named alias in the results.
  func (q *{{ $modelNameExported }}Query) WithNamed{{ .Name }}(
    name string, opts ...func(*{{ .TargetModel }}Query),
  ) *{{ $modelNameExported }}Query {
    clone := *q
    if clone.withNamed{{ .Name }} == nil {
      clone.withNamed{{ .Name }} = make(map[string]*{{ .TargetModel }}Query)
    } else {
      // deep copy the map to preserve immutability
      m := make(
        map[string]*{{ .TargetModel }}Query,
        len(clone.withNamed{{ .Name }}),
      )
      for k, v := range clone.withNamed{{ .Name }} {
        m[k] = v
      }
      clone.withNamed{{ .Name }} = m
    }

    query := New{{ .TargetModel }}Query(q.db)
    for _, opt := range opts {
      opt(query)
    }
    clone.withNamed{{ .Name }}[name] = query
    return &clone
  }
{{- end }}