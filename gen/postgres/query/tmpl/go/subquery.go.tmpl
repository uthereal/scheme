// {{ $modelNameExported }}SubQuery represents a strongly typed sub-query builder for
// the {{ .TableFullName }} table.
type {{ $modelNameExported }}SubQuery struct {
  alias     string
  selects   []rootpkg.Column
  wheres    []rootpkg.WhereCondition
  groupBys  []rootpkg.Column
  havings   []rootpkg.WhereCondition
  orderBys  []rootpkg.OrderCondition
  limit     *int
  offset    *int
}

// As aliases the table for this query.
func (q *{{ $modelNameExported }}SubQuery) As(
  alias string,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.alias = alias
  return &clone
}

// Select specifies the exact columns to retrieve from the database.
func (q *{{ $modelNameExported }}SubQuery) Select(
  cols ...rootpkg.Column,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.selects = make([]rootpkg.Column, len(q.selects), len(q.selects)+len(cols))
  copy(clone.selects, q.selects)
  clone.selects = append(clone.selects, cols...)
  return &clone
}

// Where applies one or more conditional constraints to the query.
func (q *{{ $modelNameExported }}SubQuery) Where(
  conds ...rootpkg.WhereCondition,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.wheres = make([]rootpkg.WhereCondition, len(q.wheres), len(q.wheres)+len(conds))
  copy(clone.wheres, q.wheres)
  for _, c := range conds {
    if c != nil {
      clone.wheres = append(clone.wheres, c)
    }
  }
  return &clone
}

// GroupBy specifies the columns to use for grouping the result set.
func (q *{{ $modelNameExported }}SubQuery) GroupBy(
  cols ...rootpkg.Column,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.groupBys = make([]rootpkg.Column, len(q.groupBys), len(q.groupBys)+len(cols))
  copy(clone.groupBys, q.groupBys)
  clone.groupBys = append(clone.groupBys, cols...)
  return &clone
}

// Having applies one or more conditional constraints to grouped records.
func (q *{{ $modelNameExported }}SubQuery) Having(
  conds ...rootpkg.WhereCondition,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.havings = make([]rootpkg.WhereCondition, len(q.havings), len(q.havings)+len(conds))
  copy(clone.havings, q.havings)
  for _, c := range conds {
    if c != nil {
      clone.havings = append(clone.havings, c)
    }
  }
  return &clone
}

// OrderBy applies a sorting constraint to the query.
func (q *{{ $modelNameExported }}SubQuery) OrderBy(
  conds ...rootpkg.OrderCondition,
) *{{ $modelNameExported }}SubQuery {
  clone := *q
  clone.orderBys = make(
    []rootpkg.OrderCondition, len(q.orderBys), len(q.orderBys)+len(conds),
  )
  copy(clone.orderBys, q.orderBys)
  for _, c := range conds {
