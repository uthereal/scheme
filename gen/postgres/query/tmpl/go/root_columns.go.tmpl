func (c JSONColumn[T]) buildPath(path []string) (string, []any) {
  var sql strings.Builder
  sql.WriteString("(")
  sql.WriteString(c.String())
  args := make([]any, len(path))
  for i, p := range path {
    sql.WriteString(" -> ?")
    args[i] = p
  }
  sql.WriteString(")")
  return sql.String(), args
}

// PathEq checks equality at a specific nested JSON path.
func (c JSONColumn[T]) PathEq(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " = ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathNeq checks inequality at a specific nested JSON path.
func (c JSONColumn[T]) PathNeq(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " != ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathGt checks greater-than at a specific nested JSON path.
func (c JSONColumn[T]) PathGt(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " > ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathLt checks less-than at a specific nested JSON path.
func (c JSONColumn[T]) PathLt(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " < ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathGte checks greater-than-or-equal at a specific nested JSON path.
func (c JSONColumn[T]) PathGte(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " >= ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathLte checks less-than-or-equal at a specific nested JSON path.
func (c JSONColumn[T]) PathLte(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " <= ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathContains checks if the nested JSON path contains the given value.
func (c JSONColumn[T]) PathContains(path []string, val any) WhereCondition {
  b, _ := json.Marshal(val)
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  sql + " @> ?::jsonb",
    Args: append(args, string(b)),
  }
}

// PathIsNull checks if the nested JSON path evaluates to SQL NULL or JSON
// 'null'.
func (c JSONColumn[T]) PathIsNull(path []string) WhereCondition {
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  "(" + sql + " IS NULL OR " + sql + " = 'null'::jsonb)",
    Args: append(args, args...),
  }
}

// PathIsNotNull checks if the nested JSON path exists and is not JSON 'null'.
func (c JSONColumn[T]) PathIsNotNull(path []string) WhereCondition {
  sql, args := c.buildPath(path)
  return WhereCondition{
    Sql:  "(" + sql + " IS NOT NULL AND " + sql + " != 'null'::jsonb)",
    Args: append(args, args...),
  }
}
