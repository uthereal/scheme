// IsNull returns a WhereCondition for 'IS NULL'.
func (c BaseColumn) IsNull() WhereCondition {
  return WhereCondition{Sql: c.String() + " IS NULL"}
}

// IsNotNull returns a WhereCondition for 'IS NOT NULL'.
func (c BaseColumn) IsNotNull() WhereCondition {
  return WhereCondition{Sql: c.String() + " IS NOT NULL"}
}

// IsNil is an alias for IsNull.
func (c BaseColumn) IsNil() WhereCondition {
  return c.IsNull()
}

// NotNil is an alias for IsNotNull.
func (c BaseColumn) NotNil() WhereCondition {
  return c.IsNotNull()
}

// Eq returns a WhereCondition for '='.
func (c ComparableColumn[T]) Eq(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " = ?", Args: []any{val}}
}

// EqPtr returns a WhereCondition for '='. If the provided pointer is nil,
// it falls back to returning an 'IS NULL' condition.
func (c ComparableColumn[T]) EqPtr(val *T) WhereCondition {
  if val == nil {
    return WhereCondition{Sql: c.String() + " IS NULL"}
  }
  return WhereCondition{Sql: c.String() + " = ?", Args: []any{*val}}
}

// Neq returns a WhereCondition for '!='.
func (c ComparableColumn[T]) Neq(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " != ?", Args: []any{val}}
}

// NeqPtr returns a WhereCondition for '!='. If the provided pointer is nil,
// it falls back to returning an 'IS NOT NULL' condition.
func (c ComparableColumn[T]) NeqPtr(val *T) WhereCondition {
  if val == nil {
    return WhereCondition{Sql: c.String() + " IS NOT NULL"}
  }
  return WhereCondition{Sql: c.String() + " != ?", Args: []any{*val}}
}

// In returns a WhereCondition for '= ANY()'.
func (c ArrayableColumn[T]) In(vals ...T) WhereCondition {
  if len(vals) == 0 {
    return WhereCondition{Sql: "1=0"}
  }
  return WhereCondition{Sql: c.String() + " = ANY(?)", Args: []any{vals}}
}

// NotIn returns a WhereCondition for '!= ALL()'.
func (c ArrayableColumn[T]) NotIn(vals ...T) WhereCondition {
  if len(vals) == 0 {
    return WhereCondition{Sql: "1=1"}
  }
  return WhereCondition{Sql: c.String() + " != ALL(?)", Args: []any{vals}}
}

// InQuery returns a WhereCondition for 'IN' with a sub-query.
func (c ArrayableColumn[T]) InQuery(q QueryBuilder) WhereCondition {
  return WhereCondition{Sql: c.String() + " IN", Query: q}
}

// NotInQuery returns a WhereCondition for 'NOT IN' with a sub-query.
func (c ArrayableColumn[T]) NotInQuery(q QueryBuilder) WhereCondition {
  return WhereCondition{Sql: c.String() + " NOT IN", Query: q}
}

// Gt returns a WhereCondition for '>'.
func (c OrderableColumn[T]) Gt(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " > ?", Args: []any{val}}
}

// Gte returns a WhereCondition for '>='.
func (c OrderableColumn[T]) Gte(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " >= ?", Args: []any{val}}
}

// Lt returns a WhereCondition for '<'.
func (c OrderableColumn[T]) Lt(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " < ?", Args: []any{val}}
}

// Lte returns a WhereCondition for '<='.
func (c OrderableColumn[T]) Lte(val T) WhereCondition {
  return WhereCondition{Sql: c.String() + " <= ?", Args: []any{val}}
}

