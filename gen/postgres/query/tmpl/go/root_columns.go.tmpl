// BaseColumn is the underlying root type that provides the shared methods
// for all strongly typed column representations.
type BaseColumn string

// ComparableColumn provides basic equality checks for columns.
type ComparableColumn[T any] string

// String returns the column name as a string.
func (c ComparableColumn[T]) String() string {
  return string(c)
}

// ArrayableColumn provides array inclusion constraints like IN and NOT IN.
type ArrayableColumn[T any] string

// String returns the column name as a string.
func (c ArrayableColumn[T]) String() string {
  return string(c)
}

// OrderableColumn provides mathematical inequality constraints.
type OrderableColumn[T any] string

// String returns the column name as a string.
func (c OrderableColumn[T]) String() string {
  return string(c)
}

{{- if .Active.StringColumn }}
// StringColumn represents a strongly typed PostgreSQL string/character column.
// Supported mappings: varchar, char, text, tsvector, tsquery, xml.
