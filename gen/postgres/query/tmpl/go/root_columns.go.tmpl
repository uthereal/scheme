// DynamicColumn represents a dynamically typed PostgreSQL column.
// This is primarily used as a fallback for nested fields within composite
// types where strict generic typing cannot be determined at compile time.
type DynamicColumn struct {
  BaseColumn
  ComparableColumn[any]
  ArrayableColumn[any]
  OrderableColumn[any]
}

// String resolves the ambiguous selector for the embedded String methods.
func (c DynamicColumn) String() string {
  return c.BaseColumn.String()
}

// DomainColumn represents a strongly typed PostgreSQL domain column.
// Supported mappings: domain types.
type DomainColumn[T any] struct {
  BaseColumn
  ComparableColumn[T]
}

func (c DomainColumn[T]) String() string {
  return c.BaseColumn.String()
}

// String returns the column name as a string.
func (c BaseColumn) String() string {
  return string(c)
}

// As returns a dynamic column aliased with 'AS name'.
func (c BaseColumn) As(alias string) DynamicColumn {
  sql := c.String() + " AS " + alias
  return DynamicColumn{
    BaseColumn:       BaseColumn(sql),
    ComparableColumn: ComparableColumn[any](sql),
    ArrayableColumn:  ArrayableColumn[any](sql),
    OrderableColumn:  OrderableColumn[any](sql),
  }
}

// Count returns a dynamic column formatted as 'COUNT(column)'.
func Count(c Column) DynamicColumn {
  sql := "COUNT(" + c.String() + ")"
  return DynamicColumn{
    BaseColumn:       BaseColumn(sql),
    ComparableColumn: ComparableColumn[any](sql),
    ArrayableColumn:  ArrayableColumn[any](sql),
    OrderableColumn:  OrderableColumn[any](sql),
  }
}

